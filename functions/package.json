{
  "name": "suratkama-functions",
  "description": "SuratKama Mascots — Firebase Cloud Functions (SMS + Email notifications)",
  "main": "index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "echo 'No build step needed for JS functions'",
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "axios": "^1.6.0",
    "nodemailer": "^6.9.0"
  },
  "private": true
}
