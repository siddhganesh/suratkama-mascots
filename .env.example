# ── SuratKama Mascots — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your real values.
# ⚠️  NEVER commit .env to Git — it contains secret keys!

# ── App ────────────────────────────────────────────────────────────────────────
VITE_APP_NAME=SuratKama Mascots
VITE_APP_URL=https://siddhganesh.github.io/suratkama-mascots

# ── Firebase (Database + Auth + Storage) ──────────────────────────────────────
# Get from: Firebase Console → Project Settings → Your Apps → Web App (</> button)
# All 6 values are required for live mode.
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=suratkama-mascots.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=suratkama-mascots
VITE_FIREBASE_STORAGE_BUCKET=suratkama-mascots.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abc123def456

# ── Google OAuth 2.0 (Login with Google button) ────────────────────────────────
# Get from: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Authorized JS origins: https://siddhganesh.github.io
# Authorized redirect URIs: https://siddhganesh.github.io/suratkama-mascots
VITE_GOOGLE_CLIENT_ID=1234567890-abc123.apps.googleusercontent.com

# ── Razorpay Payment Gateway ────────────────────────────────────────────────────
# Get from: Razorpay Dashboard → Settings → API Keys
# LIVE keys start with: rzp_live_
# TEST keys start with: rzp_test_  (use for testing before going live)
VITE_RAZORPAY_KEY_ID=rzp_live_...

# ── Google Analytics 4 (optional but recommended for SEO tracking) ────────────
# Get from: analytics.google.com → Admin → Data Streams → Web → Measurement ID
# Leave as-is to skip analytics in development
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ═══════════════════════════════════════════════════════════════════════════════
# FIREBASE FUNCTIONS CONFIG (set via Firebase CLI, NOT in .env)
# Run these commands once after deploying functions:
#
#   firebase functions:secrets:set FAST2SMS_KEY
#   firebase functions:secrets:set GMAIL_USER
#   firebase functions:secrets:set GMAIL_PASS
#   firebase functions:secrets:set OWNER_PHONE    → 6353046419
#   firebase functions:secrets:set OWNER_EMAIL    → your email
#
# Fast2SMS API Key: fast2sms.com → Login → Dev API → Your API key
# Gmail App Password: myaccount.google.com → Security → 2-Step Verification → App Passwords
# ═══════════════════════════════════════════════════════════════════════════════

# ── Production Checklist ──────────────────────────────────────────────────────
# 1. ✅ Firebase  → Fill all VITE_FIREBASE_* above
# 2. ✅ Google Login → Add VITE_GOOGLE_CLIENT_ID
# 3. ✅ Razorpay  → Add VITE_RAZORPAY_KEY_ID (rzp_live_...)
# 4. ✅ Analytics → Add VITE_GA_MEASUREMENT_ID
# 5. ✅ GitHub Secrets → Add all VITE_* to repo Settings → Secrets → Actions
# 6. ✅ Firebase Functions → Set secrets via firebase functions:secrets:set
# 7. ✅ Firestore Rules → Deploy: firebase deploy --only firestore
# 8. ✅ SEO → Submit public/sitemap.xml to Google Search Console
